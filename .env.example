# ============================================================
# AletheiaReproduction — 环境变量模板
# 使用方法：复制本文件为 .env 并填入真实 API Key
#   cp .env.example .env
# .env 已被 .gitignore 忽略，绝不会上传到 GitHub
# ============================================================

# ── LLM Provider 选择 ──────────────────────────────────────
# 可选值: "deepseek"（DeepSeek 官方 API）或 "volcano"（火山方舟引擎）
LLM_PROVIDER=deepseek

# ── DeepSeek 官方 API ──────────────────────────────────────
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ── 火山方舟引擎（可选，二选一）────────────────────────────
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLCANO_API_KEY=your_volcano_api_key_here
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_MODEL=deepseek-v3-2-251201

# ── Semantic Scholar API（可选，限速时推荐配置）────────────
# 获取地址: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here

# ── E2B 代码沙箱（可选，当前使用本地 subprocess 沙箱）─────
# 获取地址: https://e2b.dev/docs/getting-started/api-key
E2B_API_KEY=your_e2b_api_key_here
